        {"text": "Что такое accuracy?", "answers": [{"text": "Доля правильных предсказаний", "correct": true}, {"text": "Точность модели", "correct": false}, {"text": "Полнота модели", "correct": false}, {"text": "F1-score", "correct": false}]},
        {"text": "Что такое precision?", "answers": [{"text": "Доля правильных положительных предсказаний", "correct": true}, {"text": "Доля правильных предсказаний", "correct": false}, {"text": "Доля найденных положительных примеров", "correct": false}, {"text": "Гармоническое среднее", "correct": false}]},
        {"text": "Что такое recall?", "answers": [{"text": "Доля найденных положительных примеров", "correct": true}, {"text": "Доля правильных предсказаний", "correct": false}, {"text": "Доля правильных положительных предсказаний", "correct": false}, {"text": "Гармоническое среднее", "correct": false}]},
        {"text": "Что такое F1-score?", "answers": [{"text": "Гармоническое среднее precision и recall", "correct": true}, {"text": "Доля правильных предсказаний", "correct": false}, {"text": "Точность модели", "correct": false}, {"text": "Полнота модели", "correct": false}]},
